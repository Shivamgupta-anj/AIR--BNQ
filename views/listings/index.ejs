<% layout("layout/boilerplate") %>

            
        <!-- <h3>All Listing</h3> -->
        <!-- <form action="/listings/new" method="GET">
        <button>Create New</button>
    </form> -->

    <style>
        #filters {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
        }
        .filters{
            text-align: center;
            margin-right: 2rem;
            margin-top: 2rem;
            opacity: 0.7;
        }
        .filters:hover{
            opacity: 1;
            cursor: pointer;
        }
        .filters p{
            font-size: 0.8rem;
        }
        .tax-info{
            /* visibility: hidden; */
            display: none;

        }
        .tax-toggle{
            border: 1px solid black;
            border-radius: 1rem;
            height: 3.25rem;
            padding: 1rem;
            margin-left: 5rem;
            display: flex;
            align-items: center;

        }
    </style>

        <div id="filters">
            <div class="filters">
                <div>
                    <i class="fa-solid fa-fire"></i>
                </div>
                 <p>Trending</p>
            </div>
            <!-- rooms -->
            <div class="filters">
                <div>
                    <i class="fa-brands fa-airbnb"></i>
                </div>
                <p>Rooms</p>
            </div>
            <!-- mountains cities -->
            <div class="filters">
                <div>
                    <i class="fa-solid fa-mountain-city"></i>
                </div>
                <p>Cities</p>
            </div>
            <!-- pools -->
            <div class="filters">
                <div>
                    <i class="fa-solid fa-water-ladder"></i>
                </div>
                <p>Pools</p>
            </div>
            <!-- Beach -->
            <div class="filters">
                <div>
                    <i class="fa-solid fa-umbrella-beach"></i>
                </div>
                <p>Beach</p>
            </div>
            <!-- LakeFront-->
            <div class="filters">
                <div>
                    <i class="fa-solid fa-place-of-worship"></i>
                </div>
                <p>LakeFront</p>
            </div>
            <!-- Newspaper -->
            <div class="filters">
                <div>
                    <i class="fa-regular fa-newspaper"></i>
                </div>
                <p>Newspaper</p>
            </div>
            <!-- castles -->
            <div class="filters">
                <div>
                    <i class="fa-brands fa-fort-awesome"></i>
                </div>
                <p>Castles</p>
            </div>
            <!-- farms -->
            <div class="filters">
                <div>
                   <i class="fa-solid fa-building-wheat"></i>
                </div>
                <p>Farms</p>
            </div>
            <!-- arctic -->
            <div class="filters">
                <div>
                    <i class="fa-regular fa-snowflake"></i>
                </div>
                <p>Arctic</p>
            </div>

            <!-- dome -->

            <div class="filters">
                <div>
                    <i class="fa-solid fa-igloo"></i>
                </div>
                <p>Domes</p>
            </div>
            <!-- boad -->
            <div class="filters">
                <div>
                    <i class="fa-solid fa-ship"></i>
                </div>
                <p>Boats</p>
            </div>

            


            <div class="tax-toggle">
                <div class="form-check-reverse form-switch">
  <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
  <label class="form-check-label" for="switchCheckDefault">Display Total after Tax</label>
</div>
            </div>
            
            
            
        </div>


        <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">

            <% for (let listing of allListings){%>
                <a href="/listings/<%= listing._id %>" class="listing-link">


                    <div class="card col listing-card">
                        <img src="<%= listing.image && listing.image.url ? listing.image.url : 'https://images.unsplash.com/photo-1480714378408-67cf0d13bc1b?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80' %>" 
     class="card-img-top" 
     alt="listing image" 
     style="height: 20rem;">
                        
                            <!-- overlay -->

                        <div class="card-img-overlay"></div>
                    
                        <div class="card-body">
                            <p class="card-text">
                                <b>
                                    <%= listing.title %>
                                </b>
                                <br> - &#8377;
<%= listing.price ? listing.price.toLocaleString("en-IN") : "Price not available" %>
/ night
<i class="tax-info">&nbsp; +18% GST</i>

                            </p>
                        </div>

                    </div>
                </a>
                <% } %>

        </div>


        <script>
            let taxSwitch=document.getElementById("switchCheckDefault");
            taxSwitch.addEventListener("click",()=>{
                let taxInfo=document.getElementsByClassName("tax-info");
                for(info of taxInfo){
                    if(info.style.display!=="inline"){
                        info.style.display="inline";
                    }else{
                        info.style.display="none";
                    }
                }

                
            });
        </script>
