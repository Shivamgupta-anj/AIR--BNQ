<% layout("layout/boilerplate") %>

<style>
  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    padding: 1rem 0 0;
    border-bottom: 0.5px solid #e5e5e5;
    margin-bottom: 1.5rem;
  }
  .filter-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 5px;
    padding: 8px 16px;
    border: none;
    background: transparent;
    cursor: pointer;
    opacity: 0.55;
    border-bottom: 2px solid transparent;
    transition: opacity 0.2s, border-color 0.2s;
    color: inherit;
    text-decoration: none;
  }
  .filter-btn:hover { opacity: 1; }
  .filter-btn.active {
    opacity: 1;
    border-bottom: 2px solid #222;
  }
  .filter-btn i { font-size: 18px; }
  .filter-btn span { font-size: 11px; font-weight: 500; }

  .tax-toggle-wrap {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 14px;
    border: 0.5px solid #ddd;
    border-radius: 20px;
    font-size: 12px;
    color: #555;
    cursor: pointer;
    white-space: nowrap;
  }
  .tax-track {
    width: 28px; height: 16px;
    border-radius: 20px;
    background: #ccc;
    position: relative;
    transition: background 0.2s;
    flex-shrink: 0;
  }
  .tax-thumb {
    width: 12px; height: 12px;
    border-radius: 50%;
    background: #fff;
    position: absolute;
    top: 2px; left: 2px;
    transition: left 0.2s;
  }

  /* Listing Cards */
  .listing-link { text-decoration: none; color: inherit; }
  .listing-card {
    border-radius: 12px;
    overflow: hidden;
    border: 0.5px solid #e5e5e5;
    background: #fff;
    transition: transform 0.22s ease;
    margin-bottom: 1rem;
  }
  .listing-card:hover { transform: translateY(-4px); }
  .img-wrap { overflow: hidden; position: relative; }
  .listing-card img {
    width: 100%; height: 200px;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }
  .listing-card:hover img { transform: scale(1.04); }
  .category-badge {
    position: absolute; top: 10px; left: 10px;
    background: rgba(255,255,255,0.88);
    border-radius: 20px;
    padding: 3px 10px;
    font-size: 11px; font-weight: 500; color: #222;
  }
  .wishlist-btn {
    position: absolute; top: 10px; right: 10px;
    background: rgba(255,255,255,0.88);
    border: none; border-radius: 50%;
    width: 30px; height: 30px;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; font-size: 16px; color: #666;
    transition: color 0.2s;
  }
  .card-body { padding: 12px 14px 14px; }
  .card-title-text {
    font-size: 14px; font-weight: 500;
    margin: 0 0 3px;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .card-location { font-size: 12px; color: #888; margin: 0 0 6px; }
  .card-footer-row {
    display: flex; align-items: center;
    justify-content: space-between;
  }
  .card-price { font-size: 14px; font-weight: 500; }
  .card-price small { font-size: 12px; font-weight: 400; color: #888; }
  .tax-info { font-size: 11px; color: #888; display: none; }
  .card-rating { font-size: 12px; color: #555; }
</style>

<!-- Filter Bar -->
<div class="filter-bar">
  <% const categories = [
    { name: "Trending",  icon: "fa-solid fa-fire" },
    { name: "Rooms",     icon: "fa-brands fa-airbnb" },
    { name: "Cities",    icon: "fa-solid fa-mountain-city" },
    { name: "Pools",     icon: "fa-solid fa-water-ladder" },
    { name: "Beach",     icon: "fa-solid fa-umbrella-beach" },
    { name: "LakeFront", icon: "fa-solid fa-place-of-worship" },
    { name: "Castles",   icon: "fa-brands fa-fort-awesome" },
    { name: "Farms",     icon: "fa-solid fa-building-wheat" },
    { name: "Arctic",    icon: "fa-regular fa-snowflake" },
    { name: "Domes",     icon: "fa-solid fa-igloo" },
    { name: "Boats",     icon: "fa-solid fa-ship" },
  ]; %>

  <% for(let cat of categories){ %>
    <a href="/listings?category=<%= cat.name %>"
      class="filter-btn <%= selectedCategory === cat.name ? 'active' : '' %>">
      <i class="<%= cat.icon %>"></i>
      <span><%= cat.name %></span>
    </a>
  <% } %>

  <!-- Tax Toggle -->
  <div class="tax-toggle-wrap" id="taxToggle">
    <div class="tax-track" id="taxTrack">
      <div class="tax-thumb" id="taxThumb"></div>
    </div>
    Total after tax
  </div>
</div>

<!-- Listings Grid -->
<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 g-4 mt-1">
  <% for(let listing of allListings){ %>
  <div class="col">
    <a href="/listings/<%= listing._id %>" class="listing-link">
      <div class="listing-card">
        <div class="img-wrap">
          <img
            src="<%= listing.image && listing.image.url ? listing.image.url : 'https://images.unsplash.com/photo-1480714378408-67cf0d13bc1b?w=800&auto=format&fit=crop&q=80' %>"
            alt="listing image"
          />
          <% if(listing.category){ %>
            <span class="category-badge"><%= listing.category %></span>
          <% } %>
          <button class="wishlist-btn" onclick="event.preventDefault();toggleWish(this)">♡</button>
        </div>
        <div class="card-body">
          <p class="card-title-text"><%= listing.title %></p>
          <p class="card-location"><%= listing.location %>, <%= listing.country %></p>
          <div class="card-footer-row">
            <div class="card-price">
              ₹<%= listing.price ? listing.price.toLocaleString("en-IN") : "N/A" %>
              <small>/ night</small>
              <div class="tax-info">+18% GST</div>
            </div>
          </div>
        </div>
      </div>
    </a>
  </div>
  <% } %>
</div>

<script>
  // Filter active state (already handled by server via selectedCategory)
  // Tax toggle
  let taxOn = false;
  document.getElementById("taxToggle").addEventListener("click", () => {
    taxOn = !taxOn;
    document.getElementById("taxTrack").style.background = taxOn ? "#1D9E75" : "#ccc";
    document.getElementById("taxThumb").style.left = taxOn ? "14px" : "2px";
    document.querySelectorAll(".tax-info").forEach(t => t.style.display = taxOn ? "block" : "none");
  });

  // Wishlist heart toggle
  function toggleWish(btn) {
    const isWished = btn.textContent === "♥";
    btn.textContent = isWished ? "♡" : "♥";
    btn.style.color = isWished ? "#666" : "#e63946";
  }
</script>