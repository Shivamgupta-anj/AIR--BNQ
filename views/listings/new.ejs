<% layout("layout/boilerplate") %>

<style>
  .create-card {
    border-radius: 20px;
    box-shadow: 0 8px 25px rgba(0,0,0,0.1);
    padding: 30px;
    background: #fff;
  }

  .form-label {
    font-weight: 600;
  }

  .form-control {
    border-radius: 10px;
  }

  .form-control:focus {
    box-shadow: 0 0 8px rgba(0,123,255,0.3);
    border-color: #007bff;
  }

  .btn-create {
    background: linear-gradient(135deg, #007bff, #00c6ff);
    border: none;
    padding: 10px 25px;
    border-radius: 10px;
    font-weight: 600;
    color: white;
    transition: 0.3s;
  }

  .btn-create:hover {
    background: linear-gradient(135deg, #0056b3, #0096c7);
    transform: translateY(-2px);
  }

  .form-title {
    text-align: center;
    font-weight: 700;
    margin-bottom: 20px;
  }
</style>

<div class="container mt-5">
  <div class="row">
    <div class="col-lg-6 col-md-8 col-12 mx-auto">

      <div class="create-card">
        <h3 class="form-title"> Create New Listing</h3>

        <form action="/listings" method="POST" novalidate class="needs-validation" enctype="multipart/form-data">

          <!-- Title -->
          <div class="mb-3">
            <label class="form-label">Title</label>
            <input
              class="form-control"
              type="text"
              name="listing[title]"
              placeholder="Add a catchy title"
              required
            />
            <div class="invalid-feedback">Enter Title</div>
          </div>

          <!-- Description -->
          <div class="mb-3">
            <label class="form-label">Description</label>
            <textarea
              name="listing[description]"
              class="form-control"
              rows="3"
              placeholder="Write a short description..."
              required
            ></textarea>
            <div class="invalid-feedback">Add Description</div>
          </div>

          <!-- Image Upload -->
          <div class="mb-3">
            <label class="form-label">Upload Image</label>
            <input
              class="form-control"
              type="file"
              name="listing[image][url]"
              required
            />
          </div>

          <!-- Price + Country -->
          <div class="row">
            <div class="mb-3 col-md-4">
              <label class="form-label">Price</label>
              <input
                class="form-control"
                type="number"
                name="listing[price]"
                placeholder="₹"
                required
              />
              <div class="invalid-feedback">Please Enter Price</div>
            </div>

            <div class="mb-3 col-md-8">
              <label class="form-label">Country</label>
              <input
                class="form-control"
                type="text"
                name="listing[country]"
                placeholder="India"
                required
              />
              <div class="invalid-feedback">Enter valid country</div>
            </div>
          </div>

          <!-- Location -->
          <div class="mb-3">
            <label class="form-label">Location</label>
            <input
              class="form-control"
              type="text"
              name="listing[location]"
              placeholder="Enter location"
              required
            />
            <div class="invalid-feedback">Enter valid location</div>
          </div>

          <!-- Button -->
          <div class="text-center">
            <button class="btn btn-create mt-3">Create Listing</button>
          </div>

        </form>
      </div>

    </div>
  </div>
</div>