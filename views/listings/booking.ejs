<% layout("layout/boilerplate") %>

<style>
  * { box-sizing: border-box; }

  .booking-page {
    max-width: 980px;
    margin: 0 auto;
    padding: 2rem 1.25rem 4rem;
    font-family: 'Inter', sans-serif;
  }

  /* ── Header ── */
  .booking-header {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-bottom: 2.25rem;
  }
  .back-btn {
    width: 38px; height: 38px;
    border-radius: 50%;
    border: 0.5px solid #ddd;
    background: #fff;
    display: flex; align-items: center; justify-content: center;
    text-decoration: none;
    color: #222;
    font-size: 18px;
    transition: box-shadow 0.2s, background 0.2s;
    flex-shrink: 0;
  }
  .back-btn:hover { background: #f5f5f5; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
  .booking-header h1 {
    font-size: 24px;
    font-weight: 600;
    color: #111;
    margin: 0;
  }

  /* ── Layout ── */
  .booking-grid {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 3rem;
    align-items: start;
  }

  /* ── Steps ── */
  .step-card {
    background: #fff;
    border: 0.5px solid #e0e0e0;
    border-radius: 16px;
    padding: 1.5rem 1.75rem;
    margin-bottom: 1rem;
    transition: box-shadow 0.2s;
  }
  .step-card:hover { box-shadow: 0 2px 16px rgba(0,0,0,0.06); }

  .step-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    cursor: pointer;
    user-select: none;
  }
  .step-title {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .step-num {
    width: 28px; height: 28px;
    border-radius: 50%;
    background: #111;
    color: #fff;
    font-size: 13px;
    font-weight: 600;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .step-num.done {
    background: #0F6E56;
  }
  .step-label {
    font-size: 16px;
    font-weight: 600;
    color: #111;
  }
  .step-chevron {
    font-size: 18px;
    color: #888;
    transition: transform 0.25s;
  }
  .step-chevron.open { transform: rotate(180deg); }

  .step-body {
    margin-top: 1.25rem;
    border-top: 0.5px solid #f0f0f0;
    padding-top: 1.25rem;
    display: none;
  }
  .step-body.open { display: block; }

  /* ── Form elements ── */
  .field-group { margin-bottom: 1rem; }
  .field-label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: #777;
    display: block;
    margin-bottom: 6px;
  }
  .field-input {
    width: 100%;
    padding: 11px 14px;
    border: 0.5px solid #ddd;
    border-radius: 10px;
    font-size: 14px;
    color: #111;
    background: #fafafa;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
    font-family: inherit;
  }
  .field-input:focus {
    border-color: #085041;
    background: #fff;
    box-shadow: 0 0 0 3px rgba(8,80,65,0.08);
  }
  .field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }

  /* ── Payment methods ── */
  .payment-methods {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
    margin-bottom: 1.25rem;
  }
  .payment-opt {
    border: 0.5px solid #ddd;
    border-radius: 10px;
    padding: 12px 10px;
    text-align: center;
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
    font-size: 12px;
    color: #444;
    font-weight: 500;
  }
  .payment-opt:hover { border-color: #085041; background: #f0faf8; }
  .payment-opt.active { border-color: #085041; background: #E1F5EE; color: #085041; }
  .payment-opt-icon { font-size: 20px; display: block; margin-bottom: 5px; }

  /* ── UPI input ── */
  .upi-row {
    display: flex; gap: 8px;
  }
  .upi-row .field-input { flex: 1; }
  .upi-verify {
    padding: 11px 18px;
    background: #085041;
    color: #9FE1CB;
    border: none;
    border-radius: 10px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
    font-family: inherit;
    transition: opacity 0.2s;
  }
  .upi-verify:hover { opacity: 0.88; }

  /* ── Guests stepper ── */
  .guests-stepper {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 0;
    border-bottom: 0.5px solid #f0f0f0;
  }
  .guests-stepper:last-child { border-bottom: none; }
  .stepper-label { font-size: 14px; color: #222; font-weight: 500; }
  .stepper-sub { font-size: 12px; color: #888; }
  .stepper-controls { display: flex; align-items: center; gap: 14px; }
  .stepper-btn {
    width: 30px; height: 30px;
    border-radius: 50%;
    border: 0.5px solid #ccc;
    background: #fff;
    font-size: 18px;
    color: #555;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s;
    line-height: 1;
    font-family: inherit;
  }
  .stepper-btn:hover:not(:disabled) { border-color: #085041; color: #085041; }
  .stepper-btn:disabled { opacity: 0.3; cursor: not-allowed; }
  .stepper-val { font-size: 15px; font-weight: 500; min-width: 20px; text-align: center; }

  /* ── Date picker mini ── */
  .dates-display {
    display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 1rem;
  }
  .date-tile {
    border: 0.5px solid #ddd; border-radius: 10px; padding: 10px 14px; cursor: pointer;
    transition: border-color 0.2s;
  }
  .date-tile:hover { border-color: #085041; }
  .date-tile-label { font-size: 10px; font-weight: 600; letter-spacing: 0.07em; text-transform: uppercase; color: #888; margin-bottom: 3px; }
  .date-tile-val { font-size: 14px; font-weight: 500; color: #111; }

  /* ── Continue / Pay buttons ── */
  .cta-btn {
    width: 100%;
    padding: 13px;
    border: none;
    border-radius: 12px;
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    font-family: inherit;
    margin-top: 1rem;
    transition: opacity 0.2s, transform 0.15s;
    background: linear-gradient(135deg, #085041 0%, #0F6E56 100%);
    color: #9FE1CB;
    box-shadow: 0 4px 14px rgba(8,80,65,0.25);
    letter-spacing: 0.02em;
  }
  .cta-btn:hover { opacity: 0.9; transform: translateY(-1px); }
  .cta-btn:active { transform: translateY(0); }

  /* ── Right summary card ── */
  .summary-card {
    background: #fff;
    border: 0.5px solid #e0e0e0;
    border-radius: 20px;
    padding: 1.5rem;
    position: sticky;
    top: 80px;
    box-shadow: 0 4px 24px rgba(0,0,0,0.07);
  }

  .summary-listing {
    display: flex; gap: 14px; margin-bottom: 1.25rem;
    padding-bottom: 1.25rem;
    border-bottom: 0.5px solid #f0f0f0;
  }
  .summary-img {
    width: 90px; height: 72px;
    border-radius: 10px; object-fit: cover; flex-shrink: 0;
  }
  .summary-listing-title {
    font-size: 14px; font-weight: 600; color: #111; line-height: 1.4; margin-bottom: 4px;
  }
  .summary-rating {
    font-size: 12px; color: #555; display: flex; align-items: center; gap: 4px;
  }
  .summary-fav {
    display: inline-flex; align-items: center; gap: 4px;
    background: #f5f5f5; border-radius: 20px;
    padding: 2px 8px; font-size: 11px; color: #555; margin-top: 5px;
  }

  .cancellation-box {
    background: #f0faf8;
    border: 0.5px solid #9FE1CB;
    border-radius: 10px;
    padding: 10px 14px;
    margin-bottom: 1.25rem;
  }
  .cancellation-box p { margin: 0; font-size: 13px; }
  .cancellation-box p:first-child { font-weight: 600; color: #085041; margin-bottom: 3px; }
  .cancellation-box p:last-child { color: #555; }
  .cancellation-box a { color: #085041; font-weight: 500; }

  .summary-row {
    display: flex; justify-content: space-between;
    font-size: 13px; color: #555; margin-bottom: 8px;
  }
  .summary-row.change-row { align-items: center; }
  .change-btn {
    font-size: 12px; font-weight: 500; color: #111;
    background: #f5f5f5; border: 0.5px solid #e0e0e0;
    border-radius: 6px; padding: 3px 10px; cursor: pointer;
    font-family: inherit;
    transition: background 0.15s;
  }
  .change-btn:hover { background: #ebebeb; }

  .summary-section {
    padding: 1rem 0;
    border-top: 0.5px solid #f0f0f0;
  }
  .summary-section-title { font-size: 13px; font-weight: 600; color: #111; margin-bottom: 10px; }
  .summary-total {
    display: flex; justify-content: space-between;
    font-size: 15px; font-weight: 700; color: #111;
    padding-top: 12px;
    border-top: 0.5px solid #e0e0e0;
  }
  .summary-total span:last-child { text-decoration: underline; text-underline-offset: 3px; }

  /* ── Secure badge ── */
  .secure-note {
    display: flex; align-items: center; gap: 6px;
    font-size: 11px; color: #888; margin-top: 10px; justify-content: center;
  }

  @media (max-width: 768px) {
    .booking-grid { grid-template-columns: 1fr; }
    .summary-card { position: static; }
    .payment-methods { grid-template-columns: 1fr 1fr; }
    .field-row { grid-template-columns: 1fr; }
  }
</style>

<div class="booking-page">

  <!-- Header -->
  <div class="booking-header">
    <a href="/listings/<%= listing._id %>" class="back-btn">&#8592;</a>
    <h1>Confirm and pay</h1>
  </div>

  <div class="booking-grid">

    <!-- ════ LEFT: Steps ════ -->
    <div>

      <!-- Step 1: Login -->
      <div class="step-card" id="step1">
        <div class="step-header" onclick="toggleStep('step1')">
          <div class="step-title">
            <div class="step-num <% if(currentUser){ %>done<% } %>">
              <% if(currentUser){ %>✓<% } else { %>1<% } %>
            </div>
            <span class="step-label">
              <% if(currentUser){ %>Logged in as @<%= currentUser.username %><% } else { %>Log in or sign up<% } %>
            </span>
          </div>
          <span class="step-chevron" id="chev-step1">&#8964;</span>
        </div>
        <div class="step-body" id="body-step1">
          <% if(!currentUser){ %>
            <p style="font-size:13px;color:#555;margin-bottom:1rem;">Log in to continue with your booking.</p>
            <a href="/login" class="cta-btn" style="display:block;text-align:center;text-decoration:none;padding:13px;border-radius:12px;background:linear-gradient(135deg,#085041,#0F6E56);color:#9FE1CB;font-size:15px;font-weight:600;">
              Continue to Log in
            </a>
            <p style="font-size:12px;color:#888;text-align:center;margin-top:10px;">
              New here? <a href="/signup" style="color:#085041;font-weight:500;">Create an account</a>
            </p>
          <% } else { %>
            <div style="display:flex;align-items:center;gap:12px;padding:8px 0;">
              <div style="width:40px;height:40px;border-radius:50%;background:#E1F5EE;color:#085041;display:flex;align-items:center;justify-content:center;font-size:16px;font-weight:600;">
                <%= currentUser.username[0].toUpperCase() %>
              </div>
              <div>
                <p style="font-size:14px;font-weight:600;margin:0;color:#111;">@<%= currentUser.username %></p>
                <p style="font-size:12px;color:#888;margin:0;">Logged in</p>
              </div>
            </div>
          <% } %>
        </div>
      </div>

      <!-- Step 2: Payment -->
      <div class="step-card" id="step2">
        <div class="step-header" onclick="toggleStep('step2')">
          <div class="step-title">
            <div class="step-num">2</div>
            <span class="step-label">Add a payment method</span>
          </div>
          <span class="step-chevron" id="chev-step2">&#8964;</span>
        </div>
        <div class="step-body open" id="body-step2">

          <!-- Payment type selector -->
          <div class="payment-methods">
            <div class="payment-opt active" onclick="selectPayment(this,'upi')">
              <span class="payment-opt-icon">📱</span>UPI
            </div>
            <div class="payment-opt" onclick="selectPayment(this,'card')">
              <span class="payment-opt-icon">💳</span>Card
            </div>
            <div class="payment-opt" onclick="selectPayment(this,'netbanking')">
              <span class="payment-opt-icon">🏦</span>Net Banking
            </div>
          </div>

          <!-- UPI Fields -->
          <div id="pay-upi">
            <label class="field-label">UPI ID</label>
            <div class="upi-row">
              <input class="field-input" type="text" placeholder="yourname@upi" id="upiId" />
              <button class="upi-verify" onclick="verifyUPI()">Verify</button>
            </div>
            <p style="font-size:11px;color:#aaa;margin-top:6px;">e.g. username@okicici · username@paytm · username@ybl</p>
            <div id="upiStatus" style="display:none;font-size:12px;margin-top:8px;"></div>
          </div>

          <!-- Card Fields -->
          <div id="pay-card" style="display:none;">
            <div class="field-group">
              <label class="field-label">Card Number</label>
              <input class="field-input" type="text" placeholder="1234  5678  9012  3456" maxlength="19" id="cardNum" oninput="fmtCard(this)" />
            </div>
            <div class="field-row">
              <div class="field-group">
                <label class="field-label">Expiry</label>
                <input class="field-input" type="text" placeholder="MM / YY" maxlength="7" id="cardExp" oninput="fmtExp(this)" />
              </div>
              <div class="field-group">
                <label class="field-label">CVV</label>
                <input class="field-input" type="password" placeholder="•••" maxlength="4" />
              </div>
            </div>
            <div class="field-group">
              <label class="field-label">Name on card</label>
              <input class="field-input" type="text" placeholder="As printed on card" />
            </div>
          </div>

          <!-- Net Banking Fields -->
          <div id="pay-netbanking" style="display:none;">
            <label class="field-label">Select Bank</label>
            <select class="field-input" style="appearance:auto;">
              <option value="">-- Choose your bank --</option>
              <option>State Bank of India</option>
              <option>HDFC Bank</option>
              <option>ICICI Bank</option>
              <option>Axis Bank</option>
              <option>Kotak Mahindra Bank</option>
              <option>Punjab National Bank</option>
              <option>Bank of Baroda</option>
              <option>Yes Bank</option>
              <option>IndusInd Bank</option>
              <option>Canara Bank</option>
            </select>
            <p style="font-size:11px;color:#aaa;margin-top:8px;">You'll be redirected to your bank's secure portal to complete payment.</p>
          </div>

          <button class="cta-btn" onclick="confirmPayment()">Continue</button>

        </div>
      </div>

      <!-- Step 3: Review reservation -->
      <div class="step-card" id="step3">
        <div class="step-header" onclick="toggleStep('step3')">
          <div class="step-title">
            <div class="step-num">3</div>
            <span class="step-label">Review your reservation</span>
          </div>
          <span class="step-chevron" id="chev-step3">&#8964;</span>
        </div>
        <div class="step-body" id="body-step3">

          <!-- Dates -->
          <p style="font-size:13px;font-weight:600;color:#111;margin-bottom:8px;">Your dates</p>
          <div class="dates-display">
            <div class="date-tile">
              <div class="date-tile-label">Check-in</div>
              <div class="date-tile-val" id="reviewCheckin">—</div>
            </div>
            <div class="date-tile">
              <div class="date-tile-label">Check-out</div>
              <div class="date-tile-val" id="reviewCheckout">—</div>
            </div>
          </div>

          <!-- Guests -->
          <p style="font-size:13px;font-weight:600;color:#111;margin:1rem 0 8px;">Guests</p>
          <div class="guests-stepper">
            <div>
              <div class="stepper-label">Adults</div>
              <div class="stepper-sub">Age 13+</div>
            </div>
            <div class="stepper-controls">
              <button class="stepper-btn" onclick="changeGuest('adults',-1)" id="adultMinus">−</button>
              <span class="stepper-val" id="adultCount">1</span>
              <button class="stepper-btn" onclick="changeGuest('adults',1)">+</button>
            </div>
          </div>
          <div class="guests-stepper">
            <div>
              <div class="stepper-label">Children</div>
              <div class="stepper-sub">Ages 2–12</div>
            </div>
            <div class="stepper-controls">
              <button class="stepper-btn" onclick="changeGuest('children',-1)" id="childMinus">−</button>
              <span class="stepper-val" id="childCount">0</span>
              <button class="stepper-btn" onclick="changeGuest('children',1)">+</button>
            </div>
          </div>
          <div class="guests-stepper">
            <div>
              <div class="stepper-label">Infants</div>
              <div class="stepper-sub">Under 2</div>
            </div>
            <div class="stepper-controls">
              <button class="stepper-btn" onclick="changeGuest('infants',-1)" id="infantMinus">−</button>
              <span class="stepper-val" id="infantCount">0</span>
              <button class="stepper-btn" onclick="changeGuest('infants',1)">+</button>
            </div>
          </div>

          <!-- Special requests -->
          <div class="field-group" style="margin-top:1rem;">
            <label class="field-label">Special requests (optional)</label>
            <textarea class="field-input" rows="3" placeholder="Early check-in, dietary needs, accessibility requirements…" style="resize:vertical;"></textarea>
          </div>

          <button class="cta-btn" style="background:linear-gradient(135deg,#D4537E,#993556);" onclick="submitBooking()">
            🔒 Confirm & Pay ₹<span id="finalTotal"><%= listing.price.toLocaleString('en-IN') %></span>
          </button>
          <p class="secure-note">🔐 Payments are 256-bit SSL encrypted and secure</p>

        </div>
      </div>

    </div><!-- /left -->


    <!-- ════ RIGHT: Summary Card ════ -->
    <div>
      <div class="summary-card">

        <!-- Listing preview -->
        <div class="summary-listing">
          <img class="summary-img"
            src="<%= listing.image && listing.image.url ? listing.image.url : 'https://images.unsplash.com/photo-1568605114967-8130f3a36994?w=400' %>"
            alt="<%= listing.title %>" />
          <div>
            <p class="summary-listing-title"><%= listing.title %></p>
            <div class="summary-rating">
              <span style="color:#f5a623;">★</span>
              <span style="font-weight:600;">4.98</span>
              <span style="color:#aaa;">(188)</span>
            </div>
            <span class="summary-fav">🏅 Guest favourite</span>
          </div>
        </div>

        <!-- Cancellation -->
        <div class="cancellation-box">
          <p>✅ Free cancellation</p>
          <p>Cancel before 7 days for a full refund. <a href="#">Full policy</a></p>
        </div>

        <!-- Dates row -->
        <div class="summary-section" style="padding-top:0;border-top:none;">
          <div class="summary-row change-row">
            <div>
              <div style="font-size:12px;font-weight:600;color:#111;margin-bottom:2px;">Dates</div>
              <div style="font-size:13px;color:#555;" id="summaryDates">Select dates</div>
            </div>
            <button class="change-btn" onclick="toggleStep('step3')">Change</button>
          </div>
        </div>

        <!-- Guests row -->
        <div class="summary-section">
          <div class="summary-row change-row">
            <div>
              <div style="font-size:12px;font-weight:600;color:#111;margin-bottom:2px;">Guests</div>
              <div style="font-size:13px;color:#555;" id="summaryGuests">1 adult</div>
            </div>
            <button class="change-btn" onclick="toggleStep('step3')">Change</button>
          </div>
        </div>

        <!-- Price details -->
        <div class="summary-section">
          <div class="summary-section-title">Price details</div>
          <div class="summary-row">
            <span id="summaryNightsLabel">₹<%= listing.price.toLocaleString('en-IN') %> × 1 night</span>
            <span id="summaryNightsAmt">₹<%= listing.price.toLocaleString('en-IN') %></span>
          </div>
          <div class="summary-row">
            <span>Cleaning fee</span>
            <span>₹800</span>
          </div>
          <div class="summary-row">
            <span>Service fee</span>
            <span>₹1,200</span>
          </div>
          <div class="summary-row">
            <span>Taxes (5%)</span>
            <span id="summaryTax">₹<%= Math.round(listing.price * 0.05).toLocaleString('en-IN') %></span>
          </div>
        </div>

        <div class="summary-total">
          <span>Total INR</span>
          <span id="summaryTotal">₹<%= (listing.price + 800 + 1200 + Math.round(listing.price * 0.05)).toLocaleString('en-IN') %></span>
        </div>

        <p style="font-size:11px;color:#085041;text-align:center;margin-top:10px;cursor:pointer;font-weight:500;">
          ↓ Price breakdown
        </p>

      </div>
    </div>

  </div><!-- /booking-grid -->
</div>


<script>
  const PRICE    = <%= listing.price %>;
  const CLEANING = 800;
  const SERVICE  = 1200;

  /* ── Step accordion ── */
  function toggleStep(id) {
    const body  = document.getElementById('body-' + id);
    const chev  = document.getElementById('chev-' + id);
    const isOpen = body.classList.contains('open');
    body.classList.toggle('open', !isOpen);
    if (chev) chev.classList.toggle('open', !isOpen);
  }

  /* ── Payment method switch ── */
  function selectPayment(el, type) {
    document.querySelectorAll('.payment-opt').forEach(o => o.classList.remove('active'));
    el.classList.add('active');
    ['upi','card','netbanking'].forEach(t => {
      document.getElementById('pay-' + t).style.display = t === type ? 'block' : 'none';
    });
  }

  /* ── UPI verify mock ── */
  function verifyUPI() {
    const val = document.getElementById('upiId').value.trim();
    const status = document.getElementById('upiStatus');
    if (!val || !val.includes('@')) {
      status.style.display = 'block';
      status.style.color = '#c0392b';
      status.textContent = '✗ Enter a valid UPI ID (e.g. name@upi)';
      return;
    }
    status.style.display = 'block';
    status.style.color = '#0F6E56';
    status.textContent = '✓ UPI ID verified successfully!';
  }

  /* ── Card formatters ── */
  function fmtCard(el) {
    let v = el.value.replace(/\D/g,'').slice(0,16);
    el.value = v.match(/.{1,4}/g)?.join('  ') || v;
  }
  function fmtExp(el) {
    let v = el.value.replace(/\D/g,'').slice(0,4);
    if (v.length >= 3) v = v.slice(0,2) + ' / ' + v.slice(2);
    el.value = v;
  }

  /* ── Guest stepper ── */
  const guests = { adults: 1, children: 0, infants: 0 };
  function changeGuest(type, delta) {
    guests[type] = Math.max(0, guests[type] + delta);
    if (type === 'adults' && guests.adults < 1) guests.adults = 1;
    document.getElementById(type === 'adults' ? 'adultCount' : type === 'children' ? 'childCount' : 'infantCount').textContent = guests[type];
    document.getElementById('adultMinus').disabled  = guests.adults   <= 1;
    document.getElementById('childMinus').disabled  = guests.children <= 0;
    document.getElementById('infantMinus').disabled = guests.infants  <= 0;
    updateGuestSummary();
  }
  function updateGuestSummary() {
    let parts = [guests.adults + ' adult' + (guests.adults > 1 ? 's' : '')];
    if (guests.children) parts.push(guests.children + ' child' + (guests.children > 1 ? 'ren' : ''));
    if (guests.infants)  parts.push(guests.infants  + ' infant' + (guests.infants > 1 ? 's' : ''));
    document.getElementById('summaryGuests').textContent = parts.join(', ');
  }
  document.getElementById('adultMinus').disabled = true;

  /* ── Read dates from URL params (passed from show page) ── */
  const params = new URLSearchParams(window.location.search);
  const ciStr  = params.get('checkin');
  const coStr  = params.get('checkout');
  let nights = 1;

  if (ciStr && coStr) {
    const ci = new Date(ciStr);
    const co = new Date(coStr);
    nights = Math.max(1, Math.round((co - ci) / 86400000));

    const fmtD = d => d.toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric' });
    const fmtShort = d => d.toLocaleDateString('en-IN', { day:'numeric', month:'short' });

    document.getElementById('reviewCheckin').textContent  = fmtD(ci);
    document.getElementById('reviewCheckout').textContent = fmtD(co);
    document.getElementById('summaryDates').textContent   = fmtShort(ci) + ' – ' + fmtShort(co);
    updatePricing(nights);
  }

  function updatePricing(n) {
    const sub  = PRICE * n;
    const tax  = Math.round(sub * 0.05);
    const tot  = sub + CLEANING + SERVICE + tax;
    document.getElementById('summaryNightsLabel').textContent = '₹' + PRICE.toLocaleString('en-IN') + ' × ' + n + ' night' + (n > 1 ? 's' : '');
    document.getElementById('summaryNightsAmt').textContent   = '₹' + sub.toLocaleString('en-IN');
    document.getElementById('summaryTax').textContent         = '₹' + tax.toLocaleString('en-IN');
    document.getElementById('summaryTotal').textContent       = '₹' + tot.toLocaleString('en-IN');
    document.getElementById('finalTotal').textContent         = tot.toLocaleString('en-IN');
  }

  /* ── Step actions ── */
  function confirmPayment() {
    toggleStep('step2');
    toggleStep('step3');
    document.getElementById('step-num-2').classList.add('done');
  }

  function submitBooking() {
    alert('🎉 Booking confirmed! Thank you for choosing WanderLust.');
    window.location.href = '/listings';
  }
</script>
