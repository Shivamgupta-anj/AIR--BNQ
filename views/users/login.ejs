<% layout("/layout/boilerplate") %>

<style>
  .login-wrapper {
    display: flex;
    min-height: 88vh;
    align-items: stretch;
  }
  .login-left {
    width: 420px;
    flex-shrink: 0;
    background: #fff;
    padding: 3rem 2.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .login-left .form-control {
    background: #f8f8f8;
    border: 0.5px solid #ddd;
    font-size: 14px;
  }
  .login-left .form-label {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #666;
  }
  .login-right {
    flex: 1;
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 2.5rem;
    overflow: hidden;
  }
  .login-right img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .login-right-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(38,33,92,0.92) 0%, rgba(38,33,92,0.3) 60%, transparent 100%);
  }
  .login-right-content {
    position: relative;
  }
  .divider {
    display: flex;
    align-items: center;
    gap: 10px;
    margin: 1.25rem 0;
  }
  .divider hr {
    flex: 1;
    border: none;
    border-top: 0.5px solid #e0e0e0;
    margin: 0;
  }
  @media (max-width: 768px) {
    .login-right { display: none; }
    .login-left { width: 100%; }
  }
</style>

<div class="login-wrapper">

  <!-- Left: Form panel -->
  <div class="login-left">

    <p style="font-size:11px;font-weight:500;letter-spacing:0.1em;color:#534AB7;margin-bottom:4px;text-transform:uppercase;">Welcome back</p>
    <h3 style="font-weight:500;margin-bottom:4px;">Log in</h3>
    <p class="text-muted mb-4" style="font-size:13px;">Good to see you again</p>

    <form action="/login" method="post" class="needs-validation" novalidate>

      <div class="mb-3">
        <label for="username" class="form-label">Username</label>
        <input class="form-control" type="text" name="username" id="username"
          placeholder="Enter your username" required />
        <div class="invalid-feedback">Please enter your username.</div>
      </div>

      <div class="mb-2">
        <label for="password" class="form-label">Password</label>
        <input class="form-control" type="password" name="password" id="password"
          placeholder="Enter your password" required />
        <div class="invalid-feedback">Please enter your password.</div>
      </div>

      <div class="text-end mb-4">
        <a href="#" style="font-size:12px;color:#534AB7;text-decoration:none;font-weight:500;">Forgot password?</a>
      </div>

      <button type="submit" class="btn w-100"
        style="background:#3C3489;color:#CECBF6;font-size:14px;font-weight:500;padding:11px;border-radius:8px;letter-spacing:0.02em;">
        Log in to WanderLust
      </button>

    </form>

    <div class="divider">
      <hr/><span style="font-size:12px;color:#aaa;">or</span><hr/>
    </div>

    <p class="text-center mb-0" style="font-size:13px;color:#666;">
      New to WanderLust?
      <a href="/signup" style="color:#534AB7;font-weight:500;text-decoration:none;">Create account</a>
    </p>

  </div>

  <!-- Right: Photo panel -->
  <div class="login-right">
    <img src="https://images.unsplash.com/photo-1476514525535-07fb3b4ae5f1?w=800&auto=format&fit=crop&q=80" alt="travel">
    <div class="login-right-overlay"></div>
    <div class="login-right-content">
      <div class="d-flex align-items-center gap-2 mb-3">
        <i class="fa-solid fa-house" style="color:#AFA9EC;font-size:18px;"></i>
        <span style="color:#CECBF6;font-size:16px;font-weight:500;letter-spacing:0.04em">WanderLust</span>
      </div>
      <h2 style="color:#fff;font-weight:500;margin-bottom:6px;">Your home<br>away from home</h2>
      <p style="color:#AFA9EC;font-size:14px;margin:0;">Log in to manage your stays</p>
    </div>
  </div>

</div>